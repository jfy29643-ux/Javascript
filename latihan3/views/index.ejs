<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Katalog Utama</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 p-10">
    <div class="max-w-2xl mx-auto bg-white p-6 rounded-xl shadow">
        <h1 class="text-2xl font-bold text-center mb-6">📚 Katalog Semua Data</h1>
        
        <div class="flex justify-center gap-2 mb-6">
            <a href="/" class="bg-gray-800 text-white px-4 py-1.5 rounded-lg text-sm">Tampilkan Semua</a>
            <a href="/books" class="bg-sky-600 text-white px-4 py-1.5 rounded-lg text-sm">Daftar Buku</a>
            <a href="/authors" class="bg-green-600 text-white px-4 py-1.5 rounded-lg text-sm">Daftar Penulis</a>
        </div>

        <div id="data-container" class="space-y-3">
            <p class="text-center text-gray-400 py-4">Memuat data dari API...</p>
        </div>
    </div>

    <script>
        // Mengambil 2 API sekaligus dari backend
        Promise.all([
            fetch('/api/books').then(res => res.json()),
            fetch('/api/authors').then(res => res.json())
        ])
        .then(([dataBuku, dataPenulis]) => {
            const container = document.getElementById('data-container');
            container.innerHTML = ''; // Kosongkan indikator loading

            // Perulangan untuk membuat elemen HTML sesuai style bawaan Anda
            dataBuku.forEach(book => {
                // Cari nama penulis dari API authors
                const penulis = dataPenulis.find(p => p.id === book.authorId);
                const namaPenulis = penulis ? penulis.name : (book.authorName || 'Tidak Diketahui');

                // Render elemen HTML sesuai dengan class dan layout Tailwind Anda
                container.innerHTML += `
                    <div class="p-4 border rounded-lg bg-gray-50 flex justify-between items-center">
                        <div>
                            <h3 class="font-bold text-lg">${book.title}</h3>
                            <p class="text-sm text-gray-600">Penulis: ${namaPenulis}</p>
                            <span class="text-xs bg-gray-200 px-2 py-0.5 rounded">Genre: ${book.genre || '-'}</span>
                        </div>
                    </div>
                `;
            });
        })
        .catch(error => {
            console.error('Error fetching API:', error);
            document.getElementById('data-container').innerHTML = `
                <p class="text-center text-red-500 py-4">Gagal memuat data dari API.</p>
            `;
        });
    </script>
</body>
</html>