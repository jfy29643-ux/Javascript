<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Daftar Penulis</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-green-50 p-10">
    <div class="max-w-2xl mx-auto bg-white p-6 rounded-xl shadow">
        <h1 class="text-2xl font-bold text-green-900 mb-4">👤 Daftar Penulis</h1>
        
        <div class="mb-6">
            <a href="/" class="text-sm text-gray-600 hover:underline">← Kembali ke Beranda</a>
        </div>

        <div id="authors-container" class="space-y-3">
            <p class="text-gray-400 text-sm italic">Memuat data penulis...</p>
        </div>
    </div>

    <script>
        fetch('/api/authors')
            .then(res => res.json())
            .then(authors => {
                const container = document.getElementById('authors-container');
                container.innerHTML = ''; // Bersihkan teks loading

                if (authors.length === 0) {
                    container.innerHTML = '<p class="text-sm text-gray-500">Belum ada data penulis.</p>';
                    return;
                }

                // Render data dengan HTML & Style persis kepunyaanmu
                authors.forEach(author => {
                    container.innerHTML += `
                        <div class="p-4 border border-green-200 rounded-lg bg-green-50/50">
                            <h3 class="font-bold text-lg text-gray-800">${author.name}</h3>
                            <p class="text-xs text-gray-500">ID Penulis: ${author.id}</p>
                        </div>
                    `;
                });
            })
            .catch(err => {
                console.error('Error:', err);
                document.getElementById('authors-container').innerHTML = 
                    '<p class="text-sm text-red-500">Gagal mengambil data dari API.</p>';
            });
    </script>
</body>
</html>